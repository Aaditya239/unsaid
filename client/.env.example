# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# App Configuration
NEXT_PUBLIC_APP_NAME=UNSAID

# Auto-logout Configuration (in milliseconds)
NEXT_PUBLIC_INACTIVITY_TIMEOUT=300000    # 5 minutes
NEXT_PUBLIC_PIN_LOCK_TIMEOUT=60000       # 1 minute

# PIN Lock (for demo - in production, encrypt or store securely)
NEXT_PUBLIC_DEFAULT_PIN=1234

# Web Push Notifications (VAPID public key from server)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
